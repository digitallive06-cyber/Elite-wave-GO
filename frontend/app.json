{
  "expo": {
    "name": "Elite Wave",
    "slug": "elite-wave",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/elite-wave-logo.png",
    "scheme": "elitewave",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elitewave.iptv"
    },
    "android": {
      "package": "com.elitewave.iptv",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/elite-wave-logo.png",
        "backgroundColor": "#0A0E1A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      "expo-font",
      "expo-video",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "52bbbe40-4412-4eaa-8a15-bb8925c28bf3"
      }
    }
  }
}
